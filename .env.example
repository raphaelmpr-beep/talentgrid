# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Drizzle / Postgres)
DATABASE_URL=

# Upstash Redis (REST — used by lightweight server reads only)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# BullMQ (ioredis connection string — required for queues/workers)
REDIS_URL=

# --- Feed integrations -------------------------------------------------------
# Jobs / hiring source (primary): TheirStack
THEIRSTACK_API_KEY=
THEIRSTACK_API_BASE_URL=https://api.theirstack.com/v1
THEIRSTACK_WEBHOOK_SECRET=

# Revenue + POC enrichment provider. Treated as a single generic enrichment
# API: `${ENRICHMENT_API_BASE_URL}/companies/enrich` returns revenue, and
# `${ENRICHMENT_API_BASE_URL}/pocs/enrich` returns champion candidates.
ENRICHMENT_API_KEY=
ENRICHMENT_API_BASE_URL=

# Shared secret required to trigger non-dry-run feed syncs via
# /api/feeds/sync/*. Set in production. When unset only dryRun=true is allowed.
FEED_ADMIN_SECRET=
