# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Drizzle / Postgres)
DATABASE_URL=

# Upstash Redis (REST — used by lightweight server reads only)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# BullMQ (ioredis connection string — required for queues/workers)
REDIS_URL=

# --- Feed integrations -------------------------------------------------------
# Source-of-truth model: jobs (public.roles) are canonical; companies are the
# aggregation/UI layer. Ingestion order is TheirStack (primary) -> JobSpy
# (fallback/enrichment) -> Wikipedia/Wikidata (revenue only). Indeed is used for
# count *validation* only and is never ingested.
#
# Jobs / hiring source (PRIMARY): TheirStack. Drives /api/cron/refresh-jobs and
# the feed sync endpoints.
THEIRSTACK_API_KEY=
THEIRSTACK_API_BASE_URL=https://api.theirstack.com/v1
THEIRSTACK_WEBHOOK_SECRET=

# Jobs FALLBACK / enrichment: JobSpy. Optional HTTP endpoint returning a JSON
# array of { id, title, company, location, description }. When unset the JobSpy
# fallback is a safe no-op (returns []) and the platform runs on TheirStack
# alone. Triggered when a query/company yields <= 1 primary job.
JOBSPY_ENDPOINT=

# Cron auth: shared secret protecting /api/cron/refresh-jobs real (mutating)
# runs. Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`. Also
# accepted via x-cron-secret header or ?secret= query param. If CRON_SECRET is
# unset the endpoint falls back to FEED_ADMIN_SECRET. Without either, only
# ?dryRun=true (no writes) is permitted.
CRON_SECRET=

# Revenue + POC enrichment provider.
#
# Only ENRICHMENT_API_KEY is strictly required. The enrichment endpoint URL
# is generally dynamic — it depends on the specific champion / profile /
# company being looked up — so callers pass the canonical per-request field
# `targetUrl` in the sync body (see /api/feeds/sync/enrichment).
#
# ENRICHMENT_API_BASE_URL is OPTIONAL: when set it is used as a fallback for
# requests that do NOT supply `targetUrl` (resolves
# `${ENRICHMENT_API_BASE_URL}/companies/enrich` and
# `${ENRICHMENT_API_BASE_URL}/pocs/enrich`). If both are unset, the route
# returns `enrichment_target_url_required`.
ENRICHMENT_API_KEY=
ENRICHMENT_API_BASE_URL=

# Shared secret required to trigger non-dry-run feed syncs via
# /api/feeds/sync/*. Set in production. When unset only dryRun=true is allowed.
FEED_ADMIN_SECRET=
